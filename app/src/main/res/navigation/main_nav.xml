<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.upn.catatlari.view.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_addRunFragment"
            app:destination="@id/addRunFragment" />
    </fragment>

    <fragment
        android:id="@+id/addRunFragment"
        android:name="com.upn.catatlari.view.AddRunFragment"
        android:label="Add Run" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.upn.catatlari.view.ProfileFragment"
        android:label="Profile" />

</navigation>